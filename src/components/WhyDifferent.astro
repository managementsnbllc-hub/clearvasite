---
const values = [
  {
    accent: 'bg-lavender-400',
    title: 'Private by design',
    description: 'Your conversations stay yours. Clearva is built with privacy at its core, not as an afterthought.',
  },
  {
    accent: 'bg-warm-300',
    title: 'Clinically grounded',
    description: 'Every assessment and recommendation is informed by validated clinical frameworks like PHQ-9 and GAD-7.',
  },
  {
    accent: 'bg-lavender-300',
    title: 'Warm, not clinical',
    description: 'The experience is designed to feel human. Soft, thoughtful, and genuinely caring. Never sterile or robotic.',
  },
  {
    accent: 'bg-warm-400',
    title: 'No pressure, ever',
    description: 'Go at your own pace. There are no upsells, no urgency, no notifications pushing you to engage.',
  },
];
---

<section class="relative py-24 sm:py-32 lg:py-40 overflow-hidden">
  <!-- Warm-tinted background to differentiate from Benefits -->
  <div class="absolute inset-0 bg-gradient-to-b from-transparent via-warm-50/30 to-transparent" aria-hidden="true"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 sm:px-10">
    <div class="text-center mb-14 sm:mb-20">
      <h2
        class="font-display text-[2.25rem] sm:text-[2.75rem] lg:text-[3.25rem] text-lavender-900 leading-[1.12] tracking-tight"
        data-animate
      >
        Why it feels different
      </h2>
    </div>

    <div class="grid sm:grid-cols-2 gap-x-6 gap-y-10 sm:gap-y-14 max-w-[56rem] mx-auto">
      {values.map((value, i) => (
        <div
          class="relative pl-6 border-l-2 border-lavender-200/60"
          data-animate
          style={`transition-delay: ${100 + i * 90}ms`}
        >
          <h3 class="text-[1.0625rem] font-semibold text-lavender-900 mb-2">{value.title}</h3>
          <p class="text-gray-500 leading-[1.7] text-[0.9375rem]">{value.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
