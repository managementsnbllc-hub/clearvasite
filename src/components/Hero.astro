---
const ctaUrl = 'https://clearva.vercel.app';
---

<section class="relative min-h-[100dvh] flex items-center justify-center overflow-hidden pt-24 pb-20 sm:pt-28 sm:pb-24">
  <!-- Background gradient blobs — layered for depth -->
  <div class="absolute inset-0 overflow-hidden" aria-hidden="true">
    <div
      class="absolute -top-[25%] -right-[10%] w-[800px] h-[800px] rounded-full bg-gradient-to-br from-lavender-200/45 via-lavender-300/25 to-transparent blur-[140px] animate-float"
    ></div>
    <div
      class="absolute top-[40%] -left-[15%] w-[600px] h-[600px] rounded-full bg-gradient-to-tr from-warm-200/30 via-warm-100/20 to-transparent blur-[120px] animate-float-delayed"
    ></div>
    <div
      class="absolute -bottom-[15%] right-[15%] w-[500px] h-[500px] rounded-full bg-gradient-to-tl from-lavender-100/35 via-lavender-200/15 to-transparent blur-[100px] animate-float-slow"
    ></div>
    <!-- Subtle center radial -->
    <div
      class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[900px] h-[600px] rounded-full bg-gradient-radial from-lavender-100/20 to-transparent blur-[80px]"
    ></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 max-w-[56rem] mx-auto px-6 sm:px-10 text-center">
    <div data-animate="fade">
      <span class="inline-block px-4 py-1.5 rounded-full bg-lavender-100/70 text-lavender-600 text-[0.8125rem] font-medium tracking-wide mb-10 border border-lavender-200/40">
        Your private mental wellness companion
      </span>
    </div>

    <h1
      class="font-display text-[2.75rem] sm:text-[3.5rem] lg:text-[4.25rem] xl:text-[4.75rem] text-lavender-900 leading-[1.08] tracking-tight mb-7"
      data-animate
      style="transition-delay: 100ms"
    >
      A <em class="not-italic">gentler</em> way to understand<br class="hidden sm:block" /> how you're feeling
    </h1>

    <p
      class="text-[1.125rem] sm:text-[1.25rem] text-gray-500 leading-[1.7] max-w-[36rem] mx-auto mb-12"
      data-animate
      style="transition-delay: 200ms"
    >
      Explore your mental wellbeing through thoughtful, private conversation — not intake forms or clinical checklists.
    </p>

    <div data-animate style="transition-delay: 300ms">
      <!-- CTA with ambient glow -->
      <div class="relative inline-block">
        <div class="absolute inset-0 bg-lavender-400/25 blur-2xl rounded-full scale-[1.8] animate-pulse-glow" aria-hidden="true"></div>
        <a
          href={ctaUrl}
          class="group relative inline-flex items-center gap-2.5 px-9 py-4 bg-lavender-700 text-white text-[1.0625rem] font-medium rounded-full shadow-lg shadow-lavender-600/20 hover:bg-lavender-800 hover:shadow-xl hover:shadow-lavender-600/25 hover:-translate-y-0.5 transition-all duration-300"
        >
          Try it out
          <svg
            class="w-[18px] h-[18px] opacity-80 group-hover:translate-x-0.5 group-hover:opacity-100 transition-all duration-300"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </a>
      </div>
      <p class="mt-5 text-[0.8125rem] text-gray-400 tracking-wide">Free to use · No sign-up required</p>
    </div>
  </div>
</section>
