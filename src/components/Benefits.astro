---
const benefits = [
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 8.511c.884.284 1.5 1.128 1.5 2.097v4.286c0 1.136-.847 2.1-1.98 2.193-.34.027-.68.052-1.02.072v3.091l-3-3c-1.354 0-2.694-.055-4.02-.163a2.115 2.115 0 01-.825-.242m9.345-8.334a2.126 2.126 0 00-.476-.095 48.64 48.64 0 00-8.048 0c-1.131.094-1.976 1.057-1.976 2.192v4.286c0 .837.46 1.58 1.155 1.951m9.345-8.334V6.637c0-1.621-1.152-3.026-2.76-3.235A48.455 48.455 0 0011.25 3c-2.115 0-4.198.137-6.24.402-1.608.209-2.76 1.614-2.76 3.235v6.226c0 1.621 1.152 3.026 2.76 3.235.577.075 1.157.14 1.74.194V21l4.155-4.155" /></svg>`,
    title: 'Explore how you\'re feeling',
    description: 'Talk through what\'s on your mind in a safe, private conversation. No scripts, no rigid flows — just a space to be honest.',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5m.75-9l3-3 2.148 2.148A12.061 12.061 0 0116.5 7.605" /></svg>`,
    title: 'Understand your wellbeing',
    description: 'Clinically-informed assessments help you see where you are — not to label you, but to help you understand.',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" /></svg>`,
    title: 'Find calm when you need it',
    description: 'Breathing exercises, grounding techniques, and coping tools you can reach for in difficult moments.',
  },
  {
    icon: `<svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" /></svg>`,
    title: 'Connect with real support',
    description: 'When you\'re ready, Clearva helps you find therapists and providers who match what you\'re looking for.',
  },
];
---

<section class="relative py-24 sm:py-32 lg:py-40 overflow-hidden">
  <!-- Soft background gradient -->
  <div class="absolute inset-0 bg-gradient-to-b from-transparent via-lavender-50/35 to-transparent" aria-hidden="true"></div>

  <div class="relative z-10 max-w-[1100px] mx-auto px-6 sm:px-10">
    <div class="text-center mb-14 sm:mb-20">
      <span
        class="inline-block px-4 py-1.5 rounded-full bg-lavender-100/50 text-lavender-600 text-xs font-semibold tracking-[0.15em] uppercase mb-7"
        data-animate
      >
        What Clearva helps with
      </span>
      <h2
        class="font-display text-[2.25rem] sm:text-[2.75rem] lg:text-[3.25rem] text-lavender-900 leading-[1.12] tracking-tight"
        data-animate
        style="transition-delay: 80ms"
      >
        Here when you need it, however you need it
      </h2>
    </div>

    <div class="grid sm:grid-cols-2 gap-4 lg:gap-5 max-w-[54rem] mx-auto">
      {benefits.map((benefit, i) => (
        <div
          class="group relative bg-white/50 backdrop-blur-md border border-lavender-200/30 rounded-2xl p-7 sm:p-9 shadow-card hover:shadow-card-hover hover:border-lavender-200/50 hover:-translate-y-0.5 transition-all duration-300"
          data-animate
          style={`transition-delay: ${100 + i * 90}ms`}
        >
          <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-lavender-100 to-lavender-50 text-lavender-500 flex items-center justify-center mb-6 group-hover:from-lavender-200 group-hover:to-lavender-100 transition-all duration-300">
            <Fragment set:html={benefit.icon} />
          </div>
          <h3 class="text-[1.0625rem] font-semibold text-lavender-900 mb-2">{benefit.title}</h3>
          <p class="text-gray-500 leading-relaxed text-[0.9375rem]">{benefit.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
