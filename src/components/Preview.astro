---
---

<section class="relative py-24 sm:py-32 lg:py-40 overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 sm:px-10">
    <div class="text-center mb-14 sm:mb-16">
      <span
        class="inline-block px-4 py-1.5 rounded-full bg-lavender-100/50 text-lavender-600 text-xs font-semibold tracking-[0.15em] uppercase mb-7"
        data-animate
      >
        A glimpse inside
      </span>
      <h2
        class="font-display text-[2.25rem] sm:text-[2.75rem] lg:text-[3.25rem] text-lavender-900 leading-[1.12] tracking-tight max-w-lg mx-auto"
        data-animate
        style="transition-delay: 80ms"
      >
        Designed to feel like a safe space
      </h2>
      <p
        class="mt-5 text-[1.0625rem] sm:text-lg text-gray-500 leading-[1.7] max-w-[32rem] mx-auto"
        data-animate
        style="transition-delay: 140ms"
      >
        Every detail, from the soft colors to the gentle conversation flow, is crafted to help you feel at ease.
      </p>
    </div>

    <!-- Phone mockup -->
    <div class="flex justify-center" data-animate="scale" style="transition-delay: 200ms">
      <div class="relative" style="transform: rotate(-2deg);">
        <!-- Glow behind phone -->
        <div class="absolute inset-0 bg-gradient-to-b from-lavender-400/15 via-lavender-300/20 to-lavender-200/10 blur-[80px] scale-[1.6] rounded-full" aria-hidden="true"></div>

        <!-- Phone frame -->
        <div class="phone-frame relative w-[268px] sm:w-[296px] rounded-[42px] border-[7px] border-lavender-900/85 bg-[#faf9fe] shadow-2xl shadow-lavender-900/12 overflow-hidden">
          <!-- Notch -->
          <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[90px] h-[22px] bg-lavender-900/85 rounded-b-2xl z-10"></div>

          <!-- Screen content -->
          <div class="pt-7 pb-0 sm:h-full sm:flex sm:flex-col">
            <!-- App header -->
            <div class="px-4 py-2.5 border-b border-lavender-200/40 flex items-center justify-between">
              <span class="font-display italic text-lavender-800 text-[13px]">clearva</span>
              <div class="w-5 h-5 rounded-full bg-lavender-100 flex items-center justify-center">
                <div class="w-2 h-2 rounded-full bg-lavender-400"></div>
              </div>
            </div>

            <!-- Chat area -->
            <div class="sm:flex-1 px-3 py-2 sm:py-3 space-y-2 sm:space-y-2.5 overflow-hidden">
              <!-- Bot message -->
              <div class="flex gap-1.5 items-end">
                <div class="w-4 h-4 rounded-full bg-lavender-200 flex-shrink-0 mb-0.5"></div>
                <div class="bg-white rounded-2xl rounded-bl-md px-3 py-2 text-[9px] sm:text-[10px] leading-[1.5] text-gray-700 max-w-[80%] shadow-sm border border-lavender-100/50">
                  Hi there. How are you feeling today?
                </div>
              </div>

              <!-- User message -->
              <div class="flex justify-end">
                <div class="bg-lavender-200/80 rounded-2xl rounded-br-md px-3 py-2 text-[9px] sm:text-[10px] leading-[1.5] text-lavender-900 max-w-[72%]">
                  I've been feeling anxious lately, especially at night
                </div>
              </div>

              <!-- Bot message -->
              <div class="flex gap-1.5 items-end">
                <div class="w-4 h-4 rounded-full bg-lavender-200 flex-shrink-0 mb-0.5"></div>
                <div class="bg-white rounded-2xl rounded-bl-md px-3 py-2 text-[9px] sm:text-[10px] leading-[1.5] text-gray-700 max-w-[80%] shadow-sm border border-lavender-100/50">
                  Thank you for sharing that. It takes courage to put those feelings into words. Can you tell me more about what the anxiety feels like?
                </div>
              </div>

              <!-- User message -->
              <div class="flex justify-end">
                <div class="bg-lavender-200/80 rounded-2xl rounded-br-md px-3 py-2 text-[9px] sm:text-[10px] leading-[1.5] text-lavender-900 max-w-[72%]">
                  It's like this tightness in my chest
                </div>
              </div>

              <!-- Bot message with coping suggestion -->
              <div class="flex gap-1.5 items-end">
                <div class="w-4 h-4 rounded-full bg-lavender-200 flex-shrink-0 mb-0.5"></div>
                <div class="bg-white rounded-2xl rounded-bl-md px-3 py-2 text-[9px] sm:text-[10px] leading-[1.5] text-gray-700 max-w-[80%] shadow-sm border border-lavender-100/50">
                  <p>I hear you. That physical sensation is really common with anxiety.</p>
                  <div class="mt-1.5 px-2 py-1.5 rounded-lg bg-lavender-50 border border-lavender-200/60 text-lavender-700">
                    <span class="text-[9px] font-medium">Would you like to try a breathing exercise?</span>
                  </div>
                </div>
              </div>
            </div>

            <!-- Input bar -->
            <div class="px-3 py-2 border-t border-lavender-200/40">
              <div class="flex items-center gap-2 bg-white rounded-full px-3 py-1.5 border border-lavender-200/50 shadow-sm">
                <span class="text-[9px] text-gray-400 flex-1">Share what's on your mind...</span>
                <div class="w-5 h-5 rounded-full bg-lavender-600 flex items-center justify-center">
                  <svg class="w-2.5 h-2.5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 10.5L12 3m0 0l7.5 7.5M12 3v18" />
                  </svg>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @media (min-width: 640px) {
    .phone-frame {
      aspect-ratio: 9 / 19.5;
    }
  }
</style>
