---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Benefits from '../components/Benefits.astro';
import HowItWorks from '../components/HowItWorks.astro';
import WhyDifferent from '../components/WhyDifferent.astro';
import Preview from '../components/Preview.astro';
import FinalCTA from '../components/FinalCTA.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Clearva — A gentler way to understand how you're feeling"
  description="Clearva is a private, AI-guided companion for mental wellness. Explore your emotions, understand your wellbeing, and find support — at your own pace."
>
  <Nav />
  <main>
    <Hero />
    <About />
    <Benefits />
    <HowItWorks />
    <WhyDifferent />
    <Preview />
    <FinalCTA />
  </main>
  <Footer />
</Layout>
